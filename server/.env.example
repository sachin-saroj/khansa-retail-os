# ==========================================
# Server Configuration
# ==========================================
# Port on which the Express server will run
PORT=5000

# Environment mode (development, test, or production)
NODE_ENV=development

# ==========================================
# Database Configuration
# ==========================================
# PostgreSQL connection string
# Format: postgres://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgres://your_db_user:your_db_password@localhost:5432/khansa_retail_os

# ==========================================
# Authentication / JWT Secrets
# ==========================================
# Secret key for signing short-lived access tokens
# Generate a strong random string using crypto.randomBytes(32).toString('hex')
JWT_SECRET=your_super_secret_access_token_key_here

# Secret key for signing long-lived refresh tokens
# Generate a strong random string using crypto.randomBytes(32).toString('hex')
JWT_REFRESH_SECRET=your_super_secret_refresh_token_key_here

# ==========================================
# Security / CORS Configuration
# ==========================================
# The URL of your frontend application
# Used to configure Cross-Origin Resource Sharing (CORS) policies
CLIENT_URL=http://localhost:5173
